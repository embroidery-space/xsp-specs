{
  "$schema": "https://raw.githubusercontent.com/DavidAnson/markdownlint-cli2/main/schema/markdownlint-cli2-config-schema.json",
  "config": {
    "line-length": false,
    "no-inline-html": {
      "allowed_elements": ["figure", "figcaption", "img"],
    },
  },
  "customRules": ["markdownlint-sentences-per-line"],
  "gitignore": true,
  "globs": ["**/*.md"],
}
